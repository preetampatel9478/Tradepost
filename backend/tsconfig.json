{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": [
      "ES2020"
    ],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@config/*": [
        "./config/*"
      ],
      "@models/*": [
        "./models/*"
      ],
      "@routes/*": [
        "./routes/*"
      ],
      "@controllers/*": [
        "./controllers/*"
      ],
      "@services/*": [
        "./services/*"
      ],
      "@middlewares/*": [
        "./middlewares/*"
      ],
      "@utils/*": [
        "./utils/*"
      ],
      "@types/*": [
        "./types.ts"
      ]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "extends": "expo/tsconfig.base"
}
