# ===== Production Docker Compose (root) =====

# Mongo root user for initial bootstrap
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=CHANGE_ME_STRONG

# Recommended: use a dedicated DB user in production (not root).
# This URI currently uses the root user for simplicity.
MONGODB_URI=mongodb://root:CHANGE_ME_STRONG@mongodb:27017/tradepost?authSource=admin

# Redis
REDIS_URL=redis://redis:6379

# Auth
JWT_SECRET=CHANGE_ME_64+_CHARS_RANDOM

# CORS (comma-separated). For native mobile, this mainly affects any web clients/admin panels.
# Example: https://tradepost.app,https://admin.tradepost.app
ALLOWED_ORIGINS=

# Rate limit (production)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Socket.io CORS origins (comma-separated)
SOCKET_CORS_ORIGIN=

# Firebase (verification uploads, etc.)
FIREBASE_PROJECT_ID=
# IMPORTANT: Keep literal \n inside the env value (or use a secrets manager)
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
