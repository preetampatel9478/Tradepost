{
  "expo": {
    "name": "TradePost",
    "slug": "tradepost",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "userInterfaceStyle": "dark",

    "splash": {
      "image": "./src/assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F1E"
    },

    "assetBundlePatterns": [
      "**/*"
    ],

    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.tradepost.mobile"
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/adaptive-icon.png",
        "backgroundColor": "#0F0F1E"
      },
      "package": "com.traderpost.app",
      "googleServicesFile": "./android/app/google-services.json"
    },

    "web": {
      "favicon": "./src/assets/images/favicon.png"
    },

    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to upload documents.",
          "cameraPermission": "The app uses camera for document scanning."
        }
      ],

      [
        "expo-notifications",
        {
          "icon": "./src/assets/images/notification-icon.png",
          "color": "#00D084"
        }
      ],

      "expo-video",

      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.your_ios_client_id"
        }
      ],

      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],

      "expo-secure-store"
    ],

    "extra": {
      "eas": {
        "projectId": "your_project_id_here"
      },

      "googleWebClientId": "338245795398-xxxxx.apps.googleusercontent.com"
    }
  }
}